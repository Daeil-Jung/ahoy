{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" scope-check"
          }
        ]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" pre-commit"
          }
        ]
      },
      {
        "matcher": "Bash(git push*)|Bash(*deploy*)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" pre-push"
          }
        ]
      },
      {
        "matcher": "Bash(*eval_dispatch*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[CODING-HARNESS] External model evaluation running. Accept the verdict from eval_dispatch.py as-is. Do not override the verdict with your own judgment.'"
          }
        ]
      },
      {
        "matcher": "Write(*harness_state*)|Edit(*harness_state*)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" audit-final-scope"
          },
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" pre-state-write"
          }
        ]
      },
      {
        "matcher": "Bash(*ahoy-gen*)|Agent(*ahoy-gen*)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" pre-gen"
          }
        ]
      },
      {
        "matcher": "Write(*issues.json*)|Edit(*issues.json*)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" guard-eval-files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" post-edit-quality"
          },
          {
            "type": "command",
            "command": "echo '[CX-HARNESS] Post-edit auto-check: Verify the change works. If tests exist, run them silently. Record changes concretely - no vague expressions.'"
          }
        ]
      },
      {
        "matcher": "Bash(*eval_dispatch*)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" post-eval"
          },
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" circuit-breaker"
          }
        ]
      },
      {
        "matcher": "Write(*harness_state*)|Edit(*harness_state*)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_harness.py\" post-state-write"
          }
        ]
      }
    ]
  }
}
